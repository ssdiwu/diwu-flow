{"$schema": "../.claude-plugin/plugin.schema.json", "hooks": [{"event": "TaskCompleted", "hooks": [{"type": "command", "command": "python3 ${DIWU_FLOW_ROOT}/hooks/scripts/task_completed.py 2>/dev/null || true"}]}, {"event": "TaskCreated", "hooks": [{"type": "command", "command": "python3 ${DIWU_FLOW_ROOT}/hooks/scripts/task_created_validate.py 2>/dev/null || true"}]}, {"event": "PreToolExecution", "selector": {"tool": "Bash"}, "hooks": [{"type": "command", "command": "python3 ${DIWU_FLOW_ROOT}/hooks/scripts/drift_detect_pre.py 2>/dev/null || true"}]}, {"event": "Stop", "hooks": [{"type": "command", "command": "python3 ${DIWU_FLOW_ROOT}/hooks/scripts/stop_decision.py 2>/dev/null || true"}]}, {"event": "PreCompaction", "hooks": [{"type": "command", "command": "python3 ${DIWU_FLOW_ROOT}/hooks/scripts/pre_compact.py 2>/dev/null || true"}]}, {"event": "SessionStart", "hooks": [{"type": "command", "command": "python3 ${DIWU_FLOW_ROOT}/hooks/scripts/session_start.py 2>/dev/null || true"}]}]}