{
  "description": "diwu-flow 插件 hook 集合：任务生命周期、漂移检测、上下文监控、Plan→Dtask 门控、停止决策（含归档检查）、压缩检查点、会话初始化",
  "hooks": {
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/run_hook.py --event TaskCompleted --script task_completed.py --mode strict"
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/run_hook.py --event TaskCreated --script task_created_validate.py --mode strict"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/run_hook.py --event 'PreToolUse(Bash)' --script context_monitor.py --mode tolerant"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/run_hook.py --event 'PreToolUse(ExitPlanMode)' --script plan_exit_hint.py --mode tolerant"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/run_hook.py --event 'PreToolUse(Edit|Write)' --script task_entry_guard.py --mode strict"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/run_hook.py --event Stop --script stop_decision.py --mode strict"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/run_hook.py --event SessionStart --script session_start.py --mode tolerant"
          }
        ]
      }
    ]
  }
}
